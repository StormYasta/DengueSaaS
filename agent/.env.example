# Endereço público do DengueSaaS
# Exemplo: http://192.168.0.200:8090/api
SAAS_API_URL=http://IP_DO_SERVIDOR:8090/api

# Identificação da estação no SaaS
STATION_SLUG=E01
STATION_NAME=UBS Central / Boa Vista
STATION_LOCATION=São José do Rio Preto - SP
STATION_LATITUDE=-20.8126
STATION_LONGITUDE=-49.3762

# Serviço systemd que representa esta rotina na Raspberry
SERVICE_NAME=estacao-dengue.service
AGENT_VERSION=1.1.0

# A cada quantos segundos envia leitura/heartbeat
# 900 = 15 minutos
READ_INTERVAL_SECONDS=900
SAAS_TIMEOUT_SECONDS=10

# CSV local
CSV_FILE=/opt/dengue-agent/dados_estacao.csv

# Dojot / MQTT
MQTT_ENABLED=true
MQTT_BROKER=192.168.58.123
MQTT_PORT=1884
DEVICE_ID=admin:6421c9
MQTT_USER=admin:6421c9
MQTT_PASSWORD=
MQTT_TOPIC=admin:6421c9/attrs
