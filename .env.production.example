# Porta pública do painel web no servidor
APP_PORT=8080

# Banco de dados
POSTGRES_USER=dengue
POSTGRES_PASSWORD=troque_esta_senha
POSTGRES_DB=dengue_saas

# Origem pública do painel, usada pelo CORS da API
# Exemplo com IP: http://SEU_IP:8080
# Exemplo com domínio: https://monitoramento.seudominio.com.br
CORS_ORIGIN=http://localhost:8080

# Tempo sem heartbeat para considerar estação offline
OFFLINE_AFTER_SECONDS=120
